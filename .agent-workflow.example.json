{
  "plan_storage": {
    "repo_path": "~/plans"
  },

  "git": {
    "protected_branches": ["main", "master"]
  },

  "jira": {
    "enabled": true
  },

  "sandbox": {
    "network": {
      "allowed_domains": ["github.com", "api.github.com", "registry.npmjs.org"]
    },
    "filesystem": {
      "extra_deny_read": []
    }
  },

  "diff": {
    "mode": "split"
  },

  "pr": {
    "template_path": "",
    "description_skill": ""
  },

  "defaults": {
    "max_ci_fix_attempts": 3,
    "max_agent_restarts": 2,
    "polling_timeout_minutes": 60
  }
}
